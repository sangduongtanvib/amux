{
  "mcpServers": {
    "amux-orchestrator": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/Users/sang.duongtan/Documents/research/amux/amux-mcp-server.py"
      ],
      "description": "AMUX orchestration - control and monitor AI coding sessions"
    },
    "claude-in-chrome": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/claude-code-mcp-server-chrome"
      ]
    },
    "mixpeek": {
      "type": "http",
      "url": "https://mcp.mixpeek.com/mcp",
      "headers": {
        "Authorization": "Bearer ${MIXPEEK_API_KEY}"
      }
    },
    "mixpeek-ingestion": {
      "type": "http",
      "url": "https://mcp.mixpeek.com/ingestion/mcp",
      "headers": {
        "Authorization": "Bearer ${MIXPEEK_API_KEY}"
      }
    },
    "mixpeek-retrieval": {
      "type": "http",
      "url": "https://mcp.mixpeek.com/retrieval/mcp",
      "headers": {
        "Authorization": "Bearer ${MIXPEEK_API_KEY}"
      }
    },
    "mixpeek-admin": {
      "type": "http",
      "url": "https://mcp.mixpeek.com/admin/mcp",
      "headers": {
        "Authorization": "Bearer ${MIXPEEK_API_KEY}"
      }
    }
  }
}
